# Slurm version (semantic version format)
# Supported versions: 25.11.x, 25.05.x, 24.11.x
SLURM_VERSION=25.11.4

# Rocky Linux version
# Supported: 8, 9, 10
ROCKY_VERSION=10

# MySQL credentials (only for local development/testing)
MYSQL_USER=slurm
MYSQL_PASSWORD=password

# Runtime options (uncomment to use)
#EXTRA_PACKAGES=htop strace
#ROOT_PASSWORD=
#SSH_PERMIT_ROOT_LOGIN=prohibit-password
#SSH_PASSWORD_AUTH=no
